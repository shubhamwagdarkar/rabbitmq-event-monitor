{
  "title": "RabbitMQ Event Monitor",
  "uid": "rabbitmq-monitor",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total Messages In Flight",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT total_messages FROM monitor_summary ORDER BY polled_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Healthy Queues",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT healthy_queues FROM monitor_summary ORDER BY polled_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 3,
      "title": "Alerts Fired (Last Cycle)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT alerts_fired FROM monitor_summary ORDER BY polled_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Dead Letter Queues",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT dlq_count FROM monitor_summary ORDER BY polled_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Queue Depth Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT sampled_at AS time, queue_name, messages_total AS \"Messages\" FROM queue_metrics WHERE $__timeFilter(sampled_at) ORDER BY sampled_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "title": "Recent Alerts",
      "type": "table",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT fired_at AS \"Time\", severity AS \"Severity\", alert_type AS \"Type\", vhost || '/' || queue_name AS \"Queue\", current_value AS \"Value\", threshold_value AS \"Threshold\", message AS \"Details\" FROM alert_history ORDER BY fired_at DESC LIMIT 50",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "warning":  { "color": "yellow", "index": 0 } } },
                  { "type": "value", "options": { "critical": { "color": "red",    "index": 1 } } },
                  { "type": "value", "options": { "info":     { "color": "green",  "index": 2 } } }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Messages Per Queue (Current)",
      "type": "barchart",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT queue_name AS \"Queue\", messages_total AS \"Messages\" FROM queue_metrics WHERE sampled_at = (SELECT MAX(sampled_at) FROM queue_metrics) ORDER BY messages_total DESC",
          "format": "table"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xField": "Queue",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "fillOpacity": 80,
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Queue" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      }
    }
  ]
}
